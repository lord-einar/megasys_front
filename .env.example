# API Configuration
# If not set, defaults will be used based on environment:
# - Development: http://localhost:4000/api
# - Production: {current-origin}/api (requires reverse proxy)
VITE_API_URL=http://localhost:4000/api

# Backend Base URL for file downloads
# If not set, defaults will be used based on environment:
# - Development: http://localhost:4000
# - Production: {current-origin} (requires reverse proxy)
VITE_BACKEND_URL=http://localhost:4000

# Application
VITE_APP_NAME=Sistema de Gestión Empresarial
VITE_APP_VERSION=1.0.0
