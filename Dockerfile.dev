# Dockerfile para desarrollo con hot-reload
FROM node:18-alpine

WORKDIR /app

# Instalar dependencias globales si es necesario
RUN npm install -g npm@latest

# Copiar archivos de dependencias
COPY package*.json ./

# Instalar dependencias
RUN npm ci

# Copiar código fuente
COPY . .

# Exponer puerto
EXPOSE 5173

# Comando por defecto - ejecuta Vite en modo dev
CMD ["npm", "run", "dev"]
